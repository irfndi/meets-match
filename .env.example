# MeetMatch Environment Variables
# Copy this file to .dev.vars (for Cloudflare Workers) or .env as needed

# ============================================
# BOT CONFIGURATION
# ============================================

# Required: Telegram Bot Token (get from @BotFather: https://t.me/BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# ERROR TRACKING (SENTRY/GLITCHTIP)
# ============================================

# Optional: Sentry/GlitchTip DSN for error tracking
# SENTRY_DSN=https://your-key@your-glitchtip-or-sentry-url/project-id

# Optional: Environment name (default: development)
# SENTRY_ENVIRONMENT=development

# Optional: Release version identifier
# SENTRY_RELEASE=meetsmatch@1.0.0

# Optional: Enable error tracking (must be exactly "true" to enable)
# Requires SENTRY_DSN to be set
# ENABLE_SENTRY=true

# Optional: Traces sample rate for performance monitoring (default: 0.2)
# SENTRY_TRACES_SAMPLE_RATE=0.2
