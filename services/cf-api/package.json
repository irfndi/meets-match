{
  "name": "@meetsmatch/cf-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx ../../scripts/generate-version.ts cf-api && wrangler dev",
    "deploy": "CF_ENV=development tsx ../../scripts/generate-version.ts cf-api && wrangler deploy --env dev",
    "build": "tsx ../../scripts/generate-version.ts cf-api && tsc -p tsconfig.json",
    "test": "vitest",
    "lint": "tsx ../../scripts/generate-version.ts cf-api && tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "@effect/sql": "^0.51.1",
    "@meetsmatch/cf-shared": "file:../../packages/cf-shared",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.91.0"
  }
}
